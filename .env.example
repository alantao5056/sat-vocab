# --- Databases ---

# Management database (users, sessions). Path to a SQLite file.
MANAGEMENT_DB_PATH=./db/management.db

# Template vocabulary database copied for each new user.
# Build it with the CSV importer in tools/csv-importer (writes a .db file).
TEMPLATE_DB_PATH=./db/template.db

# Directory where per-user vocabulary databases are stored.
USER_DB_DIR=./db/users

# --- Google OAuth (optional; required for "Continue with Google") ---
# Create credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4321/auth/google/callback
