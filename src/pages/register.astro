---
import { randomUUID } from "node:crypto";
import Layout from "../layouts/Layout.astro";
import Logo from "../components/Logo.astro";
import { getUserByEmail, createUser } from "../lib/management-db";
import { hashPassword, provisionUserDb, startSession, isGoogleConfigured } from "../lib/auth";

let error: string | null = null;
let name = "";
let email = "";

if (Astro.request.method === "POST") {
    try {
        const data = await Astro.request.formData();
        name = (data.get("name") as string)?.trim() ?? "";
        email = (data.get("email") as string)?.trim().toLowerCase() ?? "";
        const password = (data.get("password") as string) ?? "";

        if (!name || !email || !password) {
            error = "All fields are required.";
        } else if (password.length < 8) {
            error = "Password must be at least 8 characters.";
        } else if (await getUserByEmail(email)) {
            error = "An account with this email already exists.";
        } else {
            const id = randomUUID();
            const dbPath = provisionUserDb(id);
            await createUser({
                id,
                email,
                name,
                password_hash: await hashPassword(password),
                db_path: dbPath,
            });
            await startSession(Astro.cookies, id);
            return Astro.redirect("/");
        }
    } catch (e) {
        console.error("Error during registration:", e);
        error = "Something went wrong. Please try again.";
    }
}

const googleEnabled = isGoogleConfigured();
---

<Layout title="Register - SAT Vocab" showHeader={false}>
    <main>
        <div class="icon-container">
            <Logo size={70} class="main-logo" />
        </div>
        <h1>Create Account</h1>
        <p class="subtitle">Start mastering your SAT vocabulary</p>

        <form method="POST">
            <div class="input-group">
                <input type="text" name="name" required placeholder="Name" value={name} autocomplete="name" />
            </div>
            <div class="input-group">
                <input type="email" name="email" required placeholder="Email" value={email} autocomplete="email" />
            </div>
            <div class="input-group">
                <input
                    type="password"
                    name="password"
                    required
                    minlength="8"
                    placeholder="Password (min 8 characters)"
                    autocomplete="new-password"
                />
            </div>
            {error && <p class="error-msg">{error}</p>}
            <button type="submit" class="submit-btn">Create Account</button>
        </form>

        {
            googleEnabled && (
                <>
                    <div class="divider">
                        <span>or</span>
                    </div>
                    <a href="/auth/google" class="google-btn">
                        Continue with Google
                    </a>
                </>
            )
        }

        <p class="helper-text">Already have an account? <a href="/login">Log in</a></p>
    </main>
</Layout>

<style>
    main {
        flex: 1;
        width: 100%;
        max-width: 400px;
        margin: 0 auto;
        padding: 2rem;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        text-align: center;
    }

    .icon-container {
        width: 110px;
        height: 110px;
        background-color: var(--primary-blue);
        border-radius: 50%;
        display: flex;
        justify-content: center;
        align-items: center;
        margin-bottom: 2rem;
        box-shadow: 0 10px 20px rgba(79, 70, 229, 0.2);
    }

    :global(.main-logo) {
        color: var(--bg-light);
    }

    h1 {
        font-size: 2.2rem;
        font-weight: 800;
        margin-bottom: 0.75rem;
        letter-spacing: -0.5px;
    }

    .subtitle {
        font-size: 1.05rem;
        line-height: 1.5;
        color: var(--text-gray);
        margin-bottom: 2.5rem;
        max-width: 300px;
    }

    form {
        width: 100%;
        display: flex;
        flex-direction: column;
        gap: 1rem;
        margin-bottom: 1.5rem;
    }

    .input-group {
        display: flex;
        justify-content: center;
    }

    input {
        font-size: 1.1rem;
        width: 100%;
        padding: 0.9rem 1rem;
        border: 2px solid var(--border-color);
        border-radius: 12px;
        background-color: var(--card-bg);
        color: var(--text-dark);
        outline: none;
        transition: border-color 0.2s;
    }

    input:focus {
        border-color: var(--primary-blue);
    }

    .error-msg {
        color: #ef4444;
        font-size: 0.95rem;
        margin-top: -0.25rem;
    }

    .submit-btn {
        width: 100%;
        background-color: var(--primary-blue);
        color: white;
        border: none;
        padding: 1.1rem;
        border-radius: 12px;
        font-size: 1.25rem;
        font-weight: 600;
        cursor: pointer;
        transition:
            transform 0.2s ease,
            background-color 0.2s ease;
        box-shadow: 0 4px 15px rgba(79, 70, 229, 0.3);
    }

    .submit-btn:active {
        transform: scale(0.98);
        background-color: var(--primary-dark);
    }

    .divider {
        display: flex;
        align-items: center;
        width: 100%;
        margin-bottom: 1.5rem;
        color: var(--text-light-gray);
        font-size: 0.9rem;
    }

    .divider::before,
    .divider::after {
        content: "";
        flex: 1;
        height: 1px;
        background-color: var(--border-color);
    }

    .divider span {
        padding: 0 1rem;
    }

    .google-btn {
        width: 100%;
        display: inline-block;
        background-color: var(--card-bg);
        color: var(--text-dark);
        border: 2px solid var(--border-color);
        text-decoration: none;
        padding: 1rem;
        border-radius: 12px;
        font-size: 1.1rem;
        font-weight: 600;
        margin-bottom: 2rem;
        transition: border-color 0.2s ease;
    }

    .google-btn:hover {
        border-color: var(--primary-blue);
    }

    .helper-text {
        font-size: 0.95rem;
        color: var(--text-gray);
    }

    .helper-text a {
        color: var(--primary-blue);
        font-weight: 600;
        text-decoration: none;
    }

    .helper-text a:hover {
        text-decoration: underline;
    }
</style>
