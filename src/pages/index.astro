---
import Layout from "../layouts/Layout.astro";
import Logo from "../components/Logo.astro";
---

<Layout title="SAT Vocab - Master Your Vocabulary" showHeader={false}>
    <main>
        <div class="icon-container">
            <Logo size={70} class="main-logo" />
        </div>
        <h1>SAT Vocab</h1>
        <p class="subtitle">Master your SAT vocabulary with interactive flashcards</p>

        <a href="/study" class="start-btn">Start Learning</a>
        <a href="/study?mode=review" class="review-btn">Review Mode</a>
        <a href="/status" class="status-link">View Progress</a>

        <p class="helper-text">10 words • Tap cards to reveal definitions</p>
    </main>
</Layout>

<style>
    main {
        flex: 1;
        width: 100%;
        max-width: 400px;
        margin: 0 auto;
        padding: 2rem;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        text-align: center;
    }

    .icon-container {
        width: 140px;
        height: 140px;
        background-color: var(--primary-blue);
        border-radius: 50%;
        display: flex;
        justify-content: center;
        align-items: center;
        margin-bottom: 2.5rem;
        box-shadow: 0 10px 20px rgba(79, 70, 229, 0.2);
    }

    :global(.main-logo) {
        color: var(--bg-light);
    }

    h1 {
        font-size: 2.8rem;
        font-weight: 800;
        margin-bottom: 1rem;
        letter-spacing: -0.5px;
    }

    .subtitle {
        font-size: 1.15rem;
        line-height: 1.5;
        color: var(--text-gray);
        margin-bottom: 3.5rem;
        max-width: 300px;
    }

    .start-btn {
        display: inline-block;
        width: 100%;
        background-color: var(--primary-blue);
        color: white;
        text-decoration: none;
        padding: 1.1rem 2rem;
        border-radius: 12px;
        font-size: 1.25rem;
        font-weight: 600;
        margin-bottom: 1rem;
        transition:
            transform 0.2s ease,
            background-color 0.2s ease;
        box-shadow: 0 4px 15px rgba(79, 70, 229, 0.3);
    }

    .start-btn:active {
        transform: scale(0.98);
        background-color: var(--primary-dark);
    }

    .review-btn {
        display: inline-block;
        width: 100%;
        background-color: transparent;
        color: var(--primary-blue);
        border: 2px solid var(--primary-blue);
        text-decoration: none;
        padding: 1.1rem 2rem;
        border-radius: 12px;
        font-size: 1.25rem;
        font-weight: 600;
        margin-bottom: 1rem;
        transition:
            transform 0.2s ease,
            background-color 0.2s ease;
    }

    .review-btn:hover {
        background-color: var(--bg-light);
    }

    .review-btn:active {
        transform: scale(0.98);
        background-color: #e0e7ff;
    }

    .status-link {
        display: inline-block;
        color: var(--primary-blue);
        text-decoration: none;
        font-size: 1.1rem;
        font-weight: 600;
        margin-bottom: 2.5rem;
        padding: 0.5rem 1rem;
        transition: opacity 0.2s ease;
    }

    .status-link:hover {
        opacity: 0.8;
        text-decoration: underline;
    }

    .helper-text {
        font-size: 0.95rem;
        color: var(--text-light-gray);
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .helper-text::before {
        content: "";
        display: block;
        width: 4px;
        height: 4px;
        background-color: var(--text-light-gray);
        border-radius: 50%;
    }
</style>
