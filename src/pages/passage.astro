---
import {
    getVocabDb,
    addLearnMoreBonus,
    getWordsPerRound,
    buildStudyQueue,
    getCachedPassage,
    setCachedPassage,
    clearCachedPassage,
    passageMatchesWords,
    getPassageError,
    setPassageError,
    clearPassageError,
    getPassageGenerationsToday,
    recordPassageGeneration,
    type PassageSegment,
} from "../lib/vocab-db";
import { GRADES, gradeWord, todayLocal, type WordState } from "../lib/sm2";
import { generatePassage } from "../lib/passage";
import { PASSAGE_DAILY_LIMIT, DEV_EMAIL } from "../config";
import Layout from "../layouts/Layout.astro";

const db = await getVocabDb(Astro.locals.dbPath!);
const today = todayLocal();
const isDev = Astro.locals.user?.email === DEV_EMAIL;

if (Astro.request.method === "POST") {
    try {
        const formData = await Astro.request.formData();
        const action = formData.get("action");

        if (action === "another_round") {
            // Deliberately raise today's new-word cap by one round (today only).
            const roundSize = await getWordsPerRound(db);
            await addLearnMoreBonus(db, today, roundSize);
            await clearPassageError(db);
            return Astro.redirect("/passage");
        }

        if (action === "generate") {
            // Explicit generate/regenerate: always produces a fresh passage for
            // the current queue, called from the client via fetch() so the page
            // can show a loading state while this (slow) call is in flight.
            const { words: queueWords } = await buildStudyQueue(db, today);
            if (queueWords.length > 0) {
                const generationsToday = isDev ? 0 : await getPassageGenerationsToday(db, today);
                if (!isDev && generationsToday >= PASSAGE_DAILY_LIMIT) {
                    await setPassageError(db, `You've used all ${PASSAGE_DAILY_LIMIT} passage generations for today.`);
                    return Astro.redirect("/passage");
                }
                // Count the attempt (not just successes) — a failed call still
                // costs an Anthropic API request.
                if (!isDev) await recordPassageGeneration(db, today);
                try {
                    const segments = await generatePassage(queueWords);
                    await setCachedPassage(db, { wordIds: queueWords.map((w) => w.id), segments });
                    await clearPassageError(db);
                } catch (err) {
                    console.error("Passage generation failed:", err);
                    await setPassageError(db, (err as Error).message);
                }
            }
            return Astro.redirect("/passage");
        }

        const ratingsJson = formData.get("ratings") as string | null;
        if (ratingsJson) {
            const ratings: { id: number; q: number }[] = JSON.parse(ratingsJson);
            const submittedIds = ratings.map((r) => r.id);

            if (submittedIds.length > 0) {
                const placeholders = submittedIds.map(() => "?").join(",");
                const wordsResult = await db.execute({
                    sql: `SELECT id, ease, interval, reps, due, seen, first_seen_date FROM "Word" WHERE id IN (${placeholders})`,
                    args: submittedIds,
                });
                const wordsMap = new Map(wordsResult.rows.map((w) => [Number(w.id), w]));

                const updateStatements = [];
                for (const { id, q } of ratings) {
                    const row = wordsMap.get(id);
                    if (!row) continue;
                    const grade = Math.round(Number(q));
                    if (!Number.isFinite(grade) || grade < 0 || grade > 5) continue;

                    const state: WordState = {
                        ease: Number(row.ease),
                        interval: Number(row.interval),
                        reps: Number(row.reps),
                        due: (row.due as string | null) ?? null,
                        seen: Number(row.seen) === 1,
                        first_seen_date: (row.first_seen_date as string | null) ?? null,
                    };
                    const next = gradeWord(state, grade, today);

                    updateStatements.push({
                        sql: `UPDATE "Word" SET ease = ?, interval = ?, reps = ?, due = ?, seen = ?, first_seen_date = ? WHERE id = ?`,
                        args: [
                            next.ease,
                            next.interval,
                            next.reps,
                            next.due,
                            next.seen ? 1 : 0,
                            next.first_seen_date,
                            id,
                        ],
                    });
                }

                if (updateStatements.length > 0) {
                    await db.batch(updateStatements, "write");
                }
            }

            // Grading changed the queue — the cached passage is now stale.
            await clearCachedPassage(db);
            await clearPassageError(db);
            return Astro.redirect("/passage");
        }
    } catch (error) {
        console.error("Error processing submission:", error);
    }
}

// --- Build the same shared queue the flashcard page uses --------------------
const { words, stoppedByCap, introducedToday } = await buildStudyQueue(db, today);
const wordMap = new Map(words.map((w) => [w.id, w]));

// --- Daily generation quota: unlimited for the dev account. -----------------
const generationsToday = isDev ? 0 : await getPassageGenerationsToday(db, today);
const generationsRemaining = Math.max(0, PASSAGE_DAILY_LIMIT - generationsToday);

// --- Resolve the passage: reuse the cache when it matches; otherwise the page
// shows a "Generate" prompt (or a retry prompt if the last attempt failed) and
// waits for the client to POST action=generate. Generation never runs inline
// on a GET — it's a slow Anthropic call, so it always goes through the
// loading-screen flow driven by client-side JS. ---------------------------
let segments: PassageSegment[] | null = null;
let passageError: string | null = null;
let limitReached = false;

if (words.length > 0) {
    const ids = words.map((w) => w.id);
    const cached = await getCachedPassage(db);
    if (cached && passageMatchesWords(cached, ids)) {
        segments = cached.segments;
    } else {
        passageError = await getPassageError(db);
        limitReached = !isDev && generationsRemaining <= 0;
    }
}
---

<Layout title="Passage - SAT Vocab" user={Astro.locals.user}>
    <main>
        <p class="gen-limit-banner">
            {
                isDev
                    ? "Dev account — unlimited passage generations."
                    : `${generationsRemaining} of ${PASSAGE_DAILY_LIMIT} passage generations left today.`
            }
        </p>
        {
            words.length === 0 ? (
                <div class="done-state">
                    <div class="done-emoji">🎉</div>
                    <h2>You're all caught up</h2>
                    {stoppedByCap ? (
                        <Fragment>
                            <p>
                                You've hit today's new-word limit ({introducedToday} introduced). Come back tomorrow for
                                your reviews, or push ahead now.
                            </p>
                            <form method="POST">
                                <input type="hidden" name="action" value="another_round" />
                                <button class="submit-btn" type="submit">
                                    Do another round
                                </button>
                                <p class="done-note">This adds to tomorrow's review load.</p>
                            </form>
                        </Fragment>
                    ) : (
                        <p>No words are due right now. Come back tomorrow to keep your memory fresh.</p>
                    )}
                </div>
            ) : segments ? (
                <Fragment>
                    <div class="passage-wrap" id="passage-view">
                        <p class="passage-hint">Tap an underlined word to rate how well you recall it, then submit.</p>
                        <article class="passage-text">
                            {segments!.map((seg) =>
                                "wordId" in seg ? (
                                    (() => {
                                        const w = wordMap.get(seg.wordId)!;
                                        return (
                                            <button
                                                class="vocab"
                                                data-id={w.id}
                                                data-word={w.word}
                                                data-definition={w.definition}
                                                data-example={w.example}
                                            >
                                                {seg.text}
                                            </button>
                                        );
                                    })()
                                ) : (
                                    <Fragment>{seg.text}</Fragment>
                                )
                            )}
                        </article>

                        <div class="action-bar">
                            <button
                                class="secondary-btn"
                                id="new-passage-btn"
                                type="button"
                                disabled={!isDev && generationsRemaining <= 0}
                                title={
                                    !isDev && generationsRemaining <= 0 ? "Daily generation limit reached" : undefined
                                }
                            >
                                New passage
                            </button>
                            <button class="submit-btn" id="submit-btn">
                                Submit Progress
                            </button>
                        </div>
                    </div>

                    {/* Hidden form for submission */}
                    <form id="ratings-form" method="POST" style="display: none;">
                        <input type="hidden" name="ratings" id="ratings-input" />
                    </form>
                </Fragment>
            ) : (
                <div class="generate-state" id="generate-state">
                    <div class="done-emoji">{limitReached ? "⏳" : passageError ? "⚠️" : "📖"}</div>
                    <h2>
                        {limitReached
                            ? "Daily limit reached"
                            : passageError
                              ? "Couldn't generate a passage"
                              : "Generate a passage"}
                    </h2>
                    <p>
                        {limitReached
                            ? `You've used all ${PASSAGE_DAILY_LIMIT} passage generations for today. Come back tomorrow for more.`
                            : passageError
                              ? `${passageError} Make sure ANTHROPIC_API_KEY is set, then try again.`
                              : "Build a short reading passage that weaves in your current study words."}
                    </p>
                    {!limitReached && (
                        <button class="submit-btn" id="generate-btn" type="button">
                            {passageError ? "Try again" : "Generate Passage"}
                        </button>
                    )}
                </div>
            )
        }

        <div class="loading-state" id="loading-state">
            <div class="spinner" aria-hidden="true"></div>
            <p>Generating your passage&hellip;</p>
            <p>Please stay on this page.</p>
        </div>
    </main>

    <!-- Word Detail Modal -->
    <div class="modal-overlay" id="modal-overlay">
        <div class="modal-content modal-content-detail">
            <button class="close-btn" id="close-btn" aria-label="Close">&times;</button>
            <h2 class="modal-title" id="modal-title">Word</h2>

            <div class="modal-body">
                <div class="modal-info">
                    <div class="modal-section">
                        <span class="modal-label">Definition:</span>
                        <p class="modal-text" id="modal-definition"></p>
                    </div>

                    <div class="modal-section">
                        <span class="modal-label">Example:</span>
                        <p class="modal-text example-text" id="modal-example"></p>
                    </div>
                </div>

                <div class="modal-grades">
                    <p class="modal-footer-text">How well did you recall it?</p>
                    <div class="grade-list" id="modal-grade-list">
                        {
                            GRADES.map((g) => (
                                <button class={`grade-row ${g.pass ? "pass" : "fail"}`} data-q={g.q}>
                                    <span class="grade-num">{g.q}</span>
                                    <span class="grade-text">
                                        <span class="grade-label">{g.label}</span>
                                        <span class="grade-desc">{g.description}</span>
                                    </span>
                                </button>
                            ))
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Warning Modal -->
    <div class="modal-overlay" id="warning-modal-overlay">
        <div class="modal-content">
            <h2 class="modal-title">Ungraded Words</h2>

            <div class="modal-section">
                <p class="modal-text">
                    You have <strong id="unrated-count">0</strong> words that aren't graded yet. Do you want to mark them
                    all with the same grade?
                </p>
            </div>

            <div class="modal-section">
                <span class="modal-label">Select a grade:</span>
                <div class="grade-list" id="warning-grade-list">
                    {
                        GRADES.map((g) => (
                            <button class={`grade-row ${g.pass ? "pass" : "fail"}`} data-q={g.q}>
                                <span class="grade-num">{g.q}</span>
                                <span class="grade-text">
                                    <span class="grade-label">{g.label}</span>
                                    <span class="grade-desc">{g.description}</span>
                                </span>
                            </button>
                        ))
                    }
                </div>
            </div>

            <div class="warning-modal-actions">
                <button class="action-btn cancel-btn" id="warning-cancel-btn">Cancel</button>
                <button class="action-btn confirm-btn" id="warning-confirm-btn" disabled>Yes, Mark All</button>
            </div>
        </div>
    </div>
</Layout>

