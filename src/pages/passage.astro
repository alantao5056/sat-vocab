</style>

<script>
    // --- Generate / regenerate: show a loading state while the (slow) passage
    // generation request is in flight, then reload — the server has already
    // cached the result, so the reload is fast. ------------------------------
    const generateBtn = document.getElementById("generate-btn");
    const newPassageBtn = document.getElementById("new-passage-btn");
    const generateState = document.getElementById("generate-state");
    const passageView = document.getElementById("passage-view");
    const loadingState = document.getElementById("loading-state");

    async function startGenerate() {
        generateState?.style.setProperty("display", "none");
        passageView?.style.setProperty("display", "none");
        loadingState?.classList.add("active");

        try {
            await fetch("/passage", {
                method: "POST",
                body: new URLSearchParams({ action: "generate" }),
            });
        } catch (err) {
            console.error("Passage generation request failed:", err);
        }
        window.location.href = "/passage";
    }

    generateBtn?.addEventListener("click", startGenerate);
    newPassageBtn?.addEventListener("click", startGenerate);

    const modalOverlay = document.getElementById("modal-overlay");
    const closeBtn = document.getElementById("close-btn");
    const vocabTokens = document.querySelectorAll(".vocab") as NodeListOf<HTMLElement>;

    // Unique word ids in the passage (a word may appear more than once).
    const wordIds = Array.from(new Set(Array.from(vocabTokens).map((t) => t.getAttribute("data-id") || "0")));

    const modalTitle = document.getElementById("modal-title");
    const modalDefinition = document.getElementById("modal-definition");
    const modalExample = document.getElementById("modal-example");
    const modalGradeBtns = document.querySelectorAll("#modal-grade-list .grade-row");

    // Warning Modal Elements
    const warningModalOverlay = document.getElementById("warning-modal-overlay");
    const unratedCountSpan = document.getElementById("unrated-count");
    const warningGradeBtns = document.querySelectorAll("#warning-grade-list .grade-row");
    const warningCancelBtn = document.getElementById("warning-cancel-btn");
    const warningConfirmBtn = document.getElementById("warning-confirm-btn") as HTMLButtonElement | null;
    const submitBtn = document.getElementById("submit-btn") as HTMLButtonElement | null;

    const ratingsForm = document.getElementById("ratings-form") as HTMLFormElement | null;
    const ratingsInput = document.getElementById("ratings-input") as HTMLInputElement | null;

    let activeId: string | null = null;
    let warningSelectedGrade: string | null = null;

    function tokensFor(id: string): HTMLElement[] {
        return Array.from(vocabTokens).filter((t) => t.getAttribute("data-id") === id);
    }

    function gradeOf(id: string): string | null {
        const token = tokensFor(id).find((t) => t.hasAttribute("data-grade"));
        return token ? token.getAttribute("data-grade") : null;
    }

    // Apply a grade to every occurrence of the word so they tint consistently.
    function setWordGrade(id: string, q: string) {
        const pass = parseInt(q, 10) >= 3;
        tokensFor(id).forEach((t) => {
            t.setAttribute("data-grade", q);
            t.classList.toggle("graded-pass", pass);
            t.classList.toggle("graded-fail", !pass);
            t.classList.remove("unrated-error");
        });
    }

    function openModal(token: HTMLElement) {
        activeId = token.getAttribute("data-id");
        const word = token.getAttribute("data-word") || "";
        const definition = token.getAttribute("data-definition") || "";
        const example = token.getAttribute("data-example") || "";

        if (modalTitle) modalTitle.textContent = word;
        if (modalDefinition) modalDefinition.textContent = definition;
        if (modalExample) modalExample.textContent = example;

        const selected = activeId ? gradeOf(activeId) : null;
        modalGradeBtns.forEach((btn) => {
            btn.classList.toggle("selected", btn.getAttribute("data-q") === selected);
        });

        modalOverlay?.classList.add("active");
        document.body.style.overflow = "hidden";
    }

    function closeModal() {
        modalOverlay?.classList.remove("active");
        document.body.style.overflow = "";
        activeId = null;
    }

    vocabTokens.forEach((token) => {
        token.addEventListener("click", () => openModal(token));
    });

    closeBtn?.addEventListener("click", closeModal);

    modalOverlay?.addEventListener("click", (e) => {
        if (e.target === modalOverlay) closeModal();
    });

    modalGradeBtns.forEach((btn) => {
        btn.addEventListener("click", () => {
            const q = btn.getAttribute("data-q");
            if (activeId && q !== null) setWordGrade(activeId, q);
            closeModal();
        });
    });

    // Validation and Warning Modal Logic
    submitBtn?.addEventListener("click", () => {
        const ungraded = wordIds.filter((id) => gradeOf(id) === null);

        if (ungraded.length > 0) {
            ungraded.forEach((id) => tokensFor(id).forEach((t) => t.classList.add("unrated-error")));
            if (unratedCountSpan) unratedCountSpan.textContent = ungraded.length.toString();
            warningModalOverlay?.classList.add("active");
            document.body.style.overflow = "hidden";
            warningSelectedGrade = null;
            warningGradeBtns.forEach((btn) => btn.classList.remove("selected"));
            if (warningConfirmBtn) warningConfirmBtn.disabled = true;
        } else {
            const ratings = wordIds.map((id) => ({ id: parseInt(id), q: parseInt(gradeOf(id) || "0") }));

            if (submitBtn) {
                submitBtn.disabled = true;
                submitBtn.textContent = "Submitting...";
            }

            if (ratingsForm && ratingsInput) {
                ratingsInput.value = JSON.stringify(ratings);
                ratingsForm.submit();
            }
        }
    });

    warningGradeBtns.forEach((btn) => {
        btn.addEventListener("click", () => {
            warningSelectedGrade = btn.getAttribute("data-q");
            warningGradeBtns.forEach((b) => b.classList.toggle("selected", b === btn));
            if (warningConfirmBtn) warningConfirmBtn.disabled = false;
        });
    });

    warningCancelBtn?.addEventListener("click", () => {
        warningModalOverlay?.classList.remove("active");
        document.body.style.overflow = "";
    });

    warningConfirmBtn?.addEventListener("click", () => {
        if (warningSelectedGrade !== null) {
            wordIds.filter((id) => gradeOf(id) === null).forEach((id) => setWordGrade(id, warningSelectedGrade!));
            warningModalOverlay?.classList.remove("active");
            document.body.style.overflow = "";
            submitBtn?.click();
        }
    });
</script>
