---
import { getVocabDb, getEffectiveNewWordCap, addLearnMoreBonus, getWordsPerRound } from "../lib/vocab-db";
import { GRADES, gradeWord, todayLocal, type WordState } from "../lib/sm2";
import Layout from "../layouts/Layout.astro";

const db = await getVocabDb(Astro.locals.dbPath!);
const today = todayLocal();

if (Astro.request.method === "POST") {
    try {
        const formData = await Astro.request.formData();
        const action = formData.get("action");

        if (action === "another_round") {
            // Deliberately raise today's new-word cap by one round (today only).
            const roundSize = await getWordsPerRound(db);
            await addLearnMoreBonus(db, today, roundSize);
            return Astro.redirect("/study");
        }

        const ratingsJson = formData.get("ratings") as string | null;
        if (ratingsJson) {
            const ratings: { id: number; q: number }[] = JSON.parse(ratingsJson);
            const submittedIds = ratings.map((r) => r.id);

            if (submittedIds.length > 0) {
                const placeholders = submittedIds.map(() => "?").join(",");
                const wordsResult = await db.execute({
                    sql: `SELECT id, ease, interval, reps, due, seen, first_seen_date FROM "Word" WHERE id IN (${placeholders})`,
                    args: submittedIds,
                });
                const wordsMap = new Map(wordsResult.rows.map((w) => [Number(w.id), w]));

                const updateStatements = [];
                for (const { id, q } of ratings) {
                    const row = wordsMap.get(id);
                    if (!row) continue;
                    const grade = Math.round(Number(q));
                    if (!Number.isFinite(grade) || grade < 0 || grade > 5) continue;

                    const state: WordState = {
                        ease: Number(row.ease),
                        interval: Number(row.interval),
                        reps: Number(row.reps),
                        due: (row.due as string | null) ?? null,
                        seen: Number(row.seen) === 1,
                        first_seen_date: (row.first_seen_date as string | null) ?? null,
                    };
                    const next = gradeWord(state, grade, today);

                    updateStatements.push({
                        sql: `UPDATE "Word" SET ease = ?, interval = ?, reps = ?, due = ?, seen = ?, first_seen_date = ? WHERE id = ?`,
                        args: [
                            next.ease,
                            next.interval,
                            next.reps,
                            next.due,
                            next.seen ? 1 : 0,
                            next.first_seen_date,
                            id,
                        ],
                    });
                }

                if (updateStatements.length > 0) {
                    await db.batch(updateStatements, "write");
                }
            }

            return Astro.redirect("/study");
        }
    } catch (error) {
        console.error("Error processing submission:", error);
    }
}

// --- Build the session queue fresh (filter + sort, not a stored list) -------

const roundSize = await getWordsPerRound(db);
const cap = await getEffectiveNewWordCap(db, today);

const introducedResult = await db.execute({
    sql: `SELECT COUNT(*) AS n FROM "Word" WHERE first_seen_date = ?`,
    args: [today],
});
const introducedToday = Number(introducedResult.rows[0].n);

// 1-3. Due/review cards: already-seen words past their due date, most overdue first.
const dueResult = await db.execute({
    sql: `SELECT id, word, definition, example FROM "Word"
          WHERE seen = 1 AND due IS NOT NULL AND due <= ?
          ORDER BY due ASC, id ASC
          LIMIT ?`,
    args: [today, roundSize],
});
const dueWords = dueResult.rows;

// 4-5. Top up with never-seen words, never exceeding today's remaining cap.
const newAllowance = Math.max(0, cap - introducedToday);
const needNew = Math.max(0, roundSize - dueWords.length);
const takeNew = Math.min(needNew, newAllowance);

let newWords: typeof dueWords = [];
if (takeNew > 0) {
    const newResult = await db.execute({
        sql: `SELECT id, word, definition, example FROM "Word"
              WHERE seen = 0
              ORDER BY shuffle_order ASC, id ASC
              LIMIT ?`,
        args: [takeNew],
    });
    newWords = newResult.rows;
}

const words = [...dueWords, ...newWords].map((r) => ({
    id: Number(r.id),
    word: r.word as string,
    definition: r.definition as string,
    example: r.example as string,
}));

// Determine why the queue is empty so we can offer "Learn 10 more" only when
// the cap (not an exhausted deck) is what stopped us.
let unseenRemaining = 0;
if (words.length === 0) {
    const unseenResult = await db.execute(`SELECT COUNT(*) AS n FROM "Word" WHERE seen = 0`);
    unseenRemaining = Number(unseenResult.rows[0].n);
}
const stoppedByCap = words.length === 0 && dueWords.length === 0 && newAllowance === 0 && unseenRemaining > 0;

// Footer buttons run worst-to-best (0..5); the modal lists them best-first.
const footerGrades = [...GRADES].reverse();
---

<Layout title="Study - SAT Vocab" user={Astro.locals.user}>
    <main>
        {
            words.length === 0 ? (
                <div class="done-state">
                    <div class="done-emoji">🎉</div>
                    <h2>You're all caught up</h2>
                    {stoppedByCap ? (
                        <Fragment>
                            <p>
                                You've hit today's new-word limit ({introducedToday} introduced). Come back tomorrow for
                                your reviews, or push ahead now.
                            </p>
                            <form method="POST">
                                <input type="hidden" name="action" value="another_round" />
                                <button class="submit-btn" type="submit">
                                    Do another round
                                </button>
                                <p class="done-note">This adds to tomorrow's review load.</p>
                            </form>
                        </Fragment>
                    ) : (
                        <p>No words are due right now. Come back tomorrow to keep your memory fresh.</p>
                    )}
                </div>
            ) : (
                <Fragment>
                    <div class="word-grid">
                        {words.map((word) => (
                            <div
                                class="word-card"
                                data-id={word.id}
                                data-word={word.word}
                                data-definition={word.definition}
                                data-example={word.example}
                            >
                                <div class="word-content">{word.word}</div>
                                <div class="card-footer">
                                    {footerGrades.map((g) => (
                                        <button
                                            class={`grade-btn ${g.pass ? "pass" : "fail"}`}
                                            title={`${g.label} — ${g.description}`}
                                            data-q={g.q}
                                        >
                                            {g.q}
                                        </button>
                                    ))}
                                </div>
                            </div>
                        ))}
                    </div>

                    <div class="submit-container">
                        <button class="submit-btn" id="submit-btn">
                            Submit Progress
                        </button>
                    </div>

                    {/* Hidden form for submission */}
                    <form id="ratings-form" method="POST" style="display: none;">
                        <input type="hidden" name="ratings" id="ratings-input" />
                    </form>
                </Fragment>
            )
        }
    </main>

    <!-- Word Detail Modal -->
    <div class="modal-overlay" id="modal-overlay">
        <div class="modal-content modal-content-detail">
            <button class="close-btn" id="close-btn" aria-label="Close">&times;</button>
            <h2 class="modal-title" id="modal-title">Word</h2>

            <div class="modal-body">
                <div class="modal-info">
                    <div class="modal-section">
                        <span class="modal-label">Definition:</span>
                        <p class="modal-text" id="modal-definition"></p>
                    </div>

                    <div class="modal-section">
                        <span class="modal-label">Example:</span>
                        <p class="modal-text example-text" id="modal-example"></p>
                    </div>
                </div>

                <div class="modal-grades">
                    <p class="modal-footer-text">How well did you recall it?</p>
                    <div class="grade-list" id="modal-grade-list">
                        {
                            GRADES.map((g) => (
                                <button class={`grade-row ${g.pass ? "pass" : "fail"}`} data-q={g.q}>
                                    <span class="grade-num">{g.q}</span>
                                    <span class="grade-text">
                                        <span class="grade-label">{g.label}</span>
                                        <span class="grade-desc">{g.description}</span>
                                    </span>
                                </button>
                            ))
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Warning Modal -->
    <div class="modal-overlay" id="warning-modal-overlay">
        <div class="modal-content">
            <h2 class="modal-title">Ungraded Cards</h2>

            <div class="modal-section">
                <p class="modal-text">
                    You have <strong id="unrated-count">0</strong> cards that aren't graded yet. Do you want to mark them
                    all with the same grade?
                </p>
            </div>

            <div class="modal-section">
                <span class="modal-label">Select a grade:</span>
                <div class="grade-list" id="warning-grade-list">
                    {
                        GRADES.map((g) => (
                            <button class={`grade-row ${g.pass ? "pass" : "fail"}`} data-q={g.q}>
                                <span class="grade-num">{g.q}</span>
                                <span class="grade-text">
                                    <span class="grade-label">{g.label}</span>
                                    <span class="grade-desc">{g.description}</span>
                                </span>
                            </button>
                        ))
                    }
                </div>
            </div>

            <div class="warning-modal-actions">
                <button class="action-btn cancel-btn" id="warning-cancel-btn">Cancel</button>
                <button class="action-btn confirm-btn" id="warning-confirm-btn" disabled>Yes, Mark All</button>
            </div>
        </div>
    </div>
</Layout>

