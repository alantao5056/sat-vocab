<script>
    const modalOverlay = document.getElementById("modal-overlay");
    const closeBtn = document.getElementById("close-btn");
    const wordCards = document.querySelectorAll(".word-card") as NodeListOf<HTMLElement>;

    // --- Fill the screen: pick the column/row split whose cells come closest to
    // a pleasant card shape for the current card count and grid size. ---------
    const wordGrid = document.querySelector(".word-grid") as HTMLElement | null;

    function layoutGrid() {
        if (!wordGrid) return;
        const n = wordCards.length;
        if (n === 0) return;

        const width = wordGrid.clientWidth;
        const height = wordGrid.clientHeight;
        if (width === 0 || height === 0) return;

        const TARGET_RATIO = 1.4; // desired card width / height
        let bestCols = 1;
        let bestScore = Infinity;
        for (let cols = 1; cols <= n; cols++) {
            const rows = Math.ceil(n / cols);
            const cellWidth = width / cols;
            const cellHeight = height / rows;
            // Closeness to the target shape, plus a small penalty for empty cells
            // left over in the last row so we don't waste space.
            const ratioScore = Math.abs(Math.log(cellWidth / cellHeight / TARGET_RATIO));
            const emptyPenalty = (cols * rows - n) * 0.05;
            const score = ratioScore + emptyPenalty;
            if (score < bestScore) {
                bestScore = score;
                bestCols = cols;
            }
        }

        const bestRows = Math.ceil(n / bestCols);
        wordGrid.style.setProperty("--cols", String(bestCols));
        wordGrid.style.setProperty("--rows", String(bestRows));
    }

    layoutGrid();
    window.addEventListener("resize", layoutGrid);

    const modalTitle = document.getElementById("modal-title");
    const modalDefinition = document.getElementById("modal-definition");
    const modalExample = document.getElementById("modal-example");
    const modalGradeBtns = document.querySelectorAll("#modal-grade-list .grade-row");

    // Warning Modal Elements
    const warningModalOverlay = document.getElementById("warning-modal-overlay");
    const unratedCountSpan = document.getElementById("unrated-count");
    const warningGradeBtns = document.querySelectorAll("#warning-grade-list .grade-row");
    const warningCancelBtn = document.getElementById("warning-cancel-btn");
    const warningConfirmBtn = document.getElementById("warning-confirm-btn") as HTMLButtonElement | null;
    const submitBtn = document.getElementById("submit-btn") as HTMLButtonElement | null;

    const ratingsForm = document.getElementById("ratings-form") as HTMLFormElement | null;
    const ratingsInput = document.getElementById("ratings-input") as HTMLInputElement | null;

    let activeCard: HTMLElement | null = null;
    let warningSelectedGrade: string | null = null;

    function updateCardGrade(card: HTMLElement, q: string) {
        card.setAttribute("data-grade", q);
        const options = card.querySelectorAll(".grade-btn");
        options.forEach((opt) => {
            opt.classList.toggle("selected", opt.getAttribute("data-q") === q);
        });
        // Tint the card to reflect the grade: 3-5 are passes (green), 0-2 fails (red).
        const pass = parseInt(q, 10) >= 3;
        card.classList.toggle("graded-pass", pass);
        card.classList.toggle("graded-fail", !pass);
        card.classList.remove("unrated-error");
    }

    function openModal(card: HTMLElement) {
        activeCard = card;
        const word = card.getAttribute("data-word") || "";
        const definition = card.getAttribute("data-definition") || "";
        const example = card.getAttribute("data-example") || "";

        if (modalTitle) modalTitle.textContent = word;
        if (modalDefinition) modalDefinition.textContent = definition;
        if (modalExample) modalExample.textContent = example;

        // Sync modal grade buttons with the card's current selection.
        const selected = card.getAttribute("data-grade");
        modalGradeBtns.forEach((btn) => {
            btn.classList.toggle("selected", btn.getAttribute("data-q") === selected);
        });

        modalOverlay?.classList.add("active");
        document.body.style.overflow = "hidden";
    }

    function closeModal() {
        modalOverlay?.classList.remove("active");
        document.body.style.overflow = "";
        activeCard = null;
    }

    wordCards.forEach((card) => {
        card.addEventListener("click", (e) => {
            const target = e.target as HTMLElement;
            const gradeBtn = target.closest(".grade-btn");
            if (gradeBtn) {
                const q = gradeBtn.getAttribute("data-q");
                if (q !== null) updateCardGrade(card, q);
                return;
            }
            openModal(card);
        });
    });

    closeBtn?.addEventListener("click", closeModal);

    modalOverlay?.addEventListener("click", (e) => {
        if (e.target === modalOverlay) closeModal();
    });

    modalGradeBtns.forEach((btn) => {
        btn.addEventListener("click", () => {
            const q = btn.getAttribute("data-q");
            if (activeCard && q !== null) updateCardGrade(activeCard, q);
            closeModal();
        });
    });

    // Validation and Warning Modal Logic
    submitBtn?.addEventListener("click", () => {
        const ungraded = Array.from(wordCards).filter((card) => !card.hasAttribute("data-grade"));

        if (ungraded.length > 0) {
            ungraded.forEach((card) => card.classList.add("unrated-error"));
            if (unratedCountSpan) unratedCountSpan.textContent = ungraded.length.toString();
            warningModalOverlay?.classList.add("active");
            document.body.style.overflow = "hidden";
            warningSelectedGrade = null;
            warningGradeBtns.forEach((btn) => btn.classList.remove("selected"));
            if (warningConfirmBtn) warningConfirmBtn.disabled = true;
        } else {
            const ratings = Array.from(wordCards).map((card) => {
                const id = card.getAttribute("data-id") || "0";
                const q = card.getAttribute("data-grade") || "0";
                return { id: parseInt(id), q: parseInt(q) };
            });

            if (submitBtn) {
                submitBtn.disabled = true;
                submitBtn.textContent = "Submitting...";
            }

            if (ratingsForm && ratingsInput) {
                ratingsInput.value = JSON.stringify(ratings);
                ratingsForm.submit();
            }
        }
    });

    warningGradeBtns.forEach((btn) => {
        btn.addEventListener("click", () => {
            warningSelectedGrade = btn.getAttribute("data-q");
            warningGradeBtns.forEach((b) => b.classList.toggle("selected", b === btn));
            if (warningConfirmBtn) warningConfirmBtn.disabled = false;
        });
    });

    warningCancelBtn?.addEventListener("click", () => {
        warningModalOverlay?.classList.remove("active");
        document.body.style.overflow = "";
    });

    warningConfirmBtn?.addEventListener("click", () => {
        if (warningSelectedGrade !== null) {
            const ungraded = Array.from(wordCards).filter((card) => !card.hasAttribute("data-grade"));
            ungraded.forEach((card) => updateCardGrade(card, warningSelectedGrade!));
            warningModalOverlay?.classList.remove("active");
            document.body.style.overflow = "";
            submitBtn?.click();
        }
    });
</script>
